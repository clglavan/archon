# ==================================================================
#           KUBERNETES TRIAGE DEBUGGER CONFIGURATION (TEMPLATE)
# ==================================================================

# 1. LM Studio Configuration
# Model name configured in LM Studio (default is magos-k8s-0.6b)
LM_STUDIO_MODEL=magos-k8s-0.6b

# Base URL where LM Studio's Local Server is running (set to Windows host IP for WSL compatibility)
LM_STUDIO_BASE_URL=http://172.22.16.1:1234

# Generation temperature for the model (defaults to 0.0 for precise tool calling)
TEMPERATURE=0.0

# 2. Daemon Configuration
# Polling rate in seconds to check the cluster for new Warning events (default is 30)
POLL_INTERVAL_SECONDS=30

# Time-To-Live in seconds for deduplicating identical alerts (default is 300)
ALERT_TTL_SECONDS=300

# Maximum number of tool calls permitted per event triage session (default is 5)
MAX_TOOL_CALLS_PER_SESSION=5

# 3. Notification Delivery Channels (Fill in to enable)
# Google Chat Webhook URL room endpoint
GOOGLE_CHAT_WEBHOOK_URL=

# Telegram Bot Token (obtain from @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram Chat ID where alerts should be sent (group, channel, or user ID)
TELEGRAM_CHAT_ID=
